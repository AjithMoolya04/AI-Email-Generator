# -- Environment Variables ----------------------
.env
.env.local
.env.*.local
!.env.example

# -- Python ------------------------------------
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg
*.egg-info/
dist/
build/
*.whl

# Virtual environments
.venv/
venv/
env/
ENV/

# Jupyter
.ipynb_checkpoints/
*.ipynb

# mypy / pyright
.mypy_cache/
.dmypy.json
dmypy.json
.pyright/

# pytest
.pytest_cache/
.coverage
htmlcov/

# -- Node / Next.js ----------------------------
node_modules/
.next/
out/
.turbo/
.swc/

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.log

# -- OS / Editor -------------------------------
.DS_Store
Thumbs.db
desktop.ini

.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# -- Misc --------------------------------------
*.bak
*.tmp
*.orig
